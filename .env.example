# Optional ElevenLabs settings for the live voice version of the demo.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_WEBHOOK_URL=http://localhost:8000/webhooks/elevenlabs/post-call
ELEVENLABS_WEB_VOICE_URL=

# Optional Nebius settings for backend summarization, routing, QA, and escalation drafting.
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# LangSmith eval settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=multi-agent-it-support-intake-eval

# Optional token pricing for eval cost estimates
NEBIUS_INPUT_TOKEN_COST_PER_1K=0.001
NEBIUS_OUTPUT_TOKEN_COST_PER_1K=0.001

# Local demo settings
DEMO_ENV=local
